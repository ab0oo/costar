{
  "version": 1,
  "screen": {
    "id": "weather-left-b",
    "orientation": "landscape",
    "width": 320,
    "height": 240,
    "regions": [
      {
        "id": "weather-now",
        "widget": "weather-now",
        "x": 0,
        "y": 0,
        "w": 160,
        "h": 120,
        "draw_border": false
      },
      {
        "id": "forecast",
        "widget": "forecast",
        "x": 0,
        "y": 120,
        "w": 160,
        "h": 120,
        "draw_border": false
      },
      {
        "id": "clock-full",
        "widget": "clock-full",
        "x": 160,
        "y": 0,
        "w": 160,
        "h": 240,
        "draw_border": false
      }
    ]
  },
  "widget_defs": {
    "weather-now": {
      "type": "dsl",
      "update_ms": 1000,
      "settings": {
        "dsl_path": "/dsl_available/weather_now.json"
      }
    },
    "forecast": {
      "type": "dsl",
      "update_ms": 1000,
      "settings": {
        "dsl_path": "/dsl_available/forecast.json"
      }
    },
    "clock-full": {
      "type": "dsl",
      "update_ms": 1000,
      "settings": {
        "dsl_path": "/dsl_available/clock_analog_full.json"
      }
    }
  },
  "shared_lookups": {
