{
  "version": 1,
  "data": {
    "source": "websocket",
    "tls_skip_verify": true,
    "connection_profile": "{{setting.connection_profile}}",
    "cache_key": "{{setting.entity_id}}",
    "bootstrap": {
      "type": "render_template",
      "template": "{% set s = states[entity_id] %}{{ {'entity_id': entity_id,'state': (s.state if s else ''),'last_updated': (s.last_updated.isoformat() if s and s.last_updated else ''),'last_changed': (s.last_changed.isoformat() if s and s.last_changed else ''),'attributes': {'friendly_name': (s.attributes.friendly_name if s else ''),'icon': (s.attributes.icon if s else '')}} | tojson }}",
      "report_errors": true,
      "variables": {
        "entity_id": "{{setting.entity_id}}"
      }
    },
    "subscribe": {
      "type": "subscribe_trigger",
      "trigger": [
        {
          "platform": "state",
          "entity_id": "{{setting.entity_id}}"
        }
      ]
    },
    "result_path": "result",
    "event_path": "event.variables.trigger.to_state",
    "poll_ms": 3000,
    "fields": {
      "name": "attributes.friendly_name",
      "entity": "entity_id",
      "state": "state",
      "ha_icon": "attributes.icon",
      "when": {
        "path": "last_updated",
        "format": {
          "tz": "local",
          "time_format": "%H:%M"
        }
      }
    }
  },
  "ui": {
    "title": "HA Control Card",
    "nodes": [
      {
        "type": "label",
        "x": 4,
        "y": 4,
        "w": 98,
        "h": 10,
        "max_lines": 2,
        "overflow": "ellipsis",
        "font": 1,
        "color": "#C7D2D9",
        "text": "{{name}}"
      },
      {
        "type": "line",
        "x": 4,
        "y": 28,
        "x2": 102,
        "y2": 28,
        "thickness": 1,
        "color": "#1E2B3D"
      },
      {
        "type": "icon",
        "x": 6,
        "y": 36,
        "w": 24,
        "h": 24,
        "path": "http://vps.gorkos.net:8085/mdi?icon={{ha_icon}}&size=24&color={{if_eq(state,'on','FFD54A','7CE2FF')}}"
      },
      {
        "type": "label",
        "x": 36,
        "y": 40,
        "font": 2,
        "color": "#7CE2FF",
        "text": "{{state}}"
      },
      {
        "type": "line",
        "x": 4,
        "y": 66,
        "x2": 102,
        "y2": 66,
        "thickness": 1,
        "color": "#1E2B3D"
      },
      {
        "type": "label",
        "x": 4,
        "y": 74,
        "font": 1,
        "color": "#6CA0C8",
        "text": "Updated {{when}}"
      }
    ]
  }
}
