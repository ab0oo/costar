{
  "version": 1,
  "data": {
    "source": "websocket",
    "tls_skip_verify": true,
    "connection_profile": "{{setting.connection_profile}}",
    "cache_key": "ha.lights.multi",
    "bootstrap": {
      "type": "render_template",
      "template": "{% set e1 = states[entity_1] %}{% set e2 = states[entity_2] %}{% set e3 = states[entity_3] %}{% set e4 = states[entity_4] %}{% set e5 = states[entity_5] %}{% set e6 = states[entity_6] %}{{ {'rows':[{'entity_id':entity_1,'name':(e1.attributes.friendly_name if e1 else entity_1),'state':(e1.state if e1 else ''),'icon':(e1.attributes.icon if e1 else '')},{'entity_id':entity_2,'name':(e2.attributes.friendly_name if e2 else entity_2),'state':(e2.state if e2 else ''),'icon':(e2.attributes.icon if e2 else '')},{'entity_id':entity_3,'name':(e3.attributes.friendly_name if e3 else entity_3),'state':(e3.state if e3 else ''),'icon':(e3.attributes.icon if e3 else '')},{'entity_id':entity_4,'name':(e4.attributes.friendly_name if e4 else entity_4),'state':(e4.state if e4 else ''),'icon':(e4.attributes.icon if e4 else '')},{'entity_id':entity_5,'name':(e5.attributes.friendly_name if e5 else entity_5),'state':(e5.state if e5 else ''),'icon':(e5.attributes.icon if e5 else '')},{'entity_id':entity_6,'name':(e6.attributes.friendly_name if e6 else entity_6),'state':(e6.state if e6 else ''),'icon':(e6.attributes.icon if e6 else '')}], 'updated': now().isoformat()} | tojson }}",
      "report_errors": true,
      "variables": {
        "entity_1": "{{setting.entity_1}}",
        "entity_2": "{{setting.entity_2}}",
        "entity_3": "{{setting.entity_3}}",
        "entity_4": "{{setting.entity_4}}",
        "entity_5": "{{setting.entity_5}}",
        "entity_6": "{{setting.entity_6}}"
      }
    },
    "subscribe": {
      "type": "subscribe_trigger",
      "trigger": [
        {
          "platform": "state",
          "entity_id": "{{setting.entity_1}}"
        },
        {
          "platform": "state",
          "entity_id": "{{setting.entity_2}}"
        },
        {
          "platform": "state",
          "entity_id": "{{setting.entity_3}}"
        },
        {
          "platform": "state",
          "entity_id": "{{setting.entity_4}}"
        },
        {
          "platform": "state",
          "entity_id": "{{setting.entity_5}}"
        },
        {
          "platform": "state",
          "entity_id": "{{setting.entity_6}}"
        }
      ]
    },
    "result_path": "result",
    "event_path": "event.result",
    "poll_ms": 5000,
    "fields": {
      "title": {
        "path": "updated",
        "format": {
          "tz": "local",
          "time_format": "%H:%M"
        }
      },
      "n1": "rows[0].name",
      "s1": "rows[0].state",
      "i1": "rows[0].icon",
      "e1": "rows[0].entity_id",
      "n2": "rows[1].name",
      "s2": "rows[1].state",
      "i2": "rows[1].icon",
      "e2": "rows[1].entity_id",
      "n3": "rows[2].name",
      "s3": "rows[2].state",
      "i3": "rows[2].icon",
      "e3": "rows[2].entity_id",
      "n4": "rows[3].name",
      "s4": "rows[3].state",
      "i4": "rows[3].icon",
      "e4": "rows[3].entity_id",
      "n5": "rows[4].name",
      "s5": "rows[4].state",
      "i5": "rows[4].icon",
      "e5": "rows[4].entity_id",
      "n6": "rows[5].name",
      "s6": "rows[5].state",
      "i6": "rows[5].icon",
      "e6": "rows[5].entity_id"
    }
  },
