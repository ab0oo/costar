{
  "version": 1,
  "data": {
    "source": "http",
    "tls_skip_verify": false,
    "url": "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/1.0_hour.geojson",
    "poll_ms": 75000,
    "debug": true,
    "transforms": [
      {
        "op": "map",
        "from": "features",
        "to": "rows",
        "fields": {
          "lat": "geometry.coordinates[1]",
          "lon": "geometry.coordinates[0]",
          "mag": "mag"
        }
      },
      {
        "op": "filter_between",
        "from": "rows",
        "by": "lon",
        "min": "-124.85",
        "max": "-66.89"
      },
      {
        "op": "filter_between",
        "from": "rows",
        "by": "lat",
        "min": "24.40",
        "max": "49.38"
      },
      {
        "op": "project_latlon",
        "from": "rows",
        "lat_path": "lat",
        "lon_path": "lon",
        "x_field": "x",
        "y_field": "y",
        "lon_min": "-124.85",
        "lon_max": "-66.89",
        "lat_min": "24.40",
        "lat_max": "49.38",
        "x_min": "0",
        "x_max": "319",
        "y_min": "0",
        "y_max": "239",
        "clamp": true
      },
      {
        "op": "index_rows",
        "from": "rows",
        "count": 90,
        "count_key": "q_count",
        "fields": ["x", "y"],
        "prefix_map": {
          "x": "qx",
          "y": "qy"
        },
        "fill_empty": true
      }
    ],
    "fields": {
      "count": "q_count"
    }
  },
  "ui": {
    "title": "USGS Quakes US Map",
    "nodes": [
      {
        "type": "bitmap1",
        "x": 0,
        "y": 0,
        "w": 320,
        "h": 240,
        "path": "/maps/us_outline_320x240_1b.raw",
        "color": "#1A1A1A",
        "bg": "#FFFFFF"
      },
      {
        "type": "label",
        "x": 4,
        "y": 2,
        "font": 1,
        "color": "#9FD3FF",
        "text": "USGS M1.0+ (1h): {{count}}"
      },
      {
        "type": "repeat",
        "count": 90,
        "start": 1,
        "step": 1,
        "var": "i",
        "nodes": [
          {
            "type": "circle",
            "visible_if": "qx{{i}}",
            "x": "qx{{i}}",
            "y": "qy{{i}}",
            "r": 2,
            "bg": "#FF0000",
            "color": "#FF0000",
            "thickness": 1
          }
        ]
      }
    ]
  }
}
