{
  "version": 1,
  "data": {
    "source": "websocket",
    "connection_profile": "{{setting.connection_profile}}",
    "cache_key": "{{setting.entity_id}}",
    "bootstrap": {
      "type": "render_template",
      "template": "{% set s = states[entity_id] %}{{ {'entity_id': entity_id,'state': (s.state if s else ''),'last_updated': (s.last_updated.isoformat() if s and s.last_updated else ''),'last_changed': (s.last_changed.isoformat() if s and s.last_changed else ''),'attributes': {'friendly_name': (s.attributes.friendly_name if s else ''),'unit_of_measurement': (s.attributes.unit_of_measurement if s else '')}} | tojson }}",
      "report_errors": true,
      "variables": {
        "entity_id": "{{setting.entity_id}}"
      }
    },
    "subscribe": {
      "type": "subscribe_trigger",
      "trigger": [
        {
          "platform": "state",
          "entity_id": "{{setting.entity_id}}"
        }
      ]
    },
    "result_path": "result",
    "event_path": "event.variables.trigger.to_state",
    "poll_ms": 3000,
    "fields": {
      "name": "attributes.friendly_name",
      "state": "state",
      "unit": "attributes.unit_of_measurement",
      "when": "last_updated"
    }
  },
  "ui": {
    "title": "HA Entity",
    "nodes": [
      {
        "type": "label",
        "x": 6,
        "y": 6,
        "font": 2,
        "color": "#8FA0B3",
        "text": "Home Assistant"
      },
      {
        "type": "label",
        "x": 6,
        "y": 26,
        "font": 2,
        "color": "#FFFFFF",
        "text": "{{name}}"
      },
      {
        "type": "label",
        "x": 6,
        "y": 54,
        "font": 6,
        "color": "#7CE2FF",
        "text": "{{state}}"
      },
      {
        "type": "label",
        "x": 110,
        "y": 62,
        "font": 2,
        "color": "#7CE2FF",
        "text": "{{unit}}"
      }
    ]
  }
}
