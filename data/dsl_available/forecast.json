{
  "version": 1,
  "notes": {
    "weather_code_ref": "Open-Meteo weather_code uses WMO weather interpretation codes (not consecutive integers). See https://open-meteo.com/en/docs#weather_variable_documentation"
  },
  "data": {
    "source": "http",
    "tls_skip_verify": true,
    "url": "https://api.open-meteo.com/v1/forecast?latitude={{geo.lat}}&longitude={{geo.lon}}&daily=weather_code,temperature_2m_min,temperature_2m_max&timezone=UTC&forecast_days=2&temperature_unit=fahrenheit",
    "debug": true,
    "poll_ms": 600000,
    "fields": {
      "day1_name": {
        "path": "daily.time[0]",
        "format": {
          "tz": "local",
          "time_format": "%A"
        }
      },
      "day1_min": {
        "path": "daily.temperature_2m_min[0]",
        "format": {
          "round": 0,
          "locale": "en-US"
        }
      },
      "day1_max": {
        "path": "daily.temperature_2m_max[0]",
        "format": {
          "round": 0,
          "locale": "en-US"
        }
      },
      "day1_code": "daily.weather_code[0]",
      "day1_cond": {
        "path": "daily.weather_code[0]",
        "format": {
          "map_lookup": "weather_code_text",
          "map_default": "Unknown"
        }
      },
      "day1_icon": {
        "path": "daily.weather_code[0]",
        "format": {
          "map_lookup": "weather_code_icon_day",
          "map_default": "/icons/meteocons/overcast-day.raw"
        }
      },
      "day2_name": {
        "path": "daily.time[1]",
        "format": {
          "tz": "local",
          "time_format": "%A"
        }
      },
      "day2_min": {
        "path": "daily.temperature_2m_min[1]",
        "format": {
          "round": 0,
          "locale": "en-US"
        }
      },
      "day2_max": {
        "path": "daily.temperature_2m_max[1]",
        "format": {
          "round": 0,
          "locale": "en-US"
        }
      },
      "day2_code": "daily.weather_code[1]",
      "day2_cond": {
        "path": "daily.weather_code[1]",
        "format": {
          "map_lookup": "weather_code_text",
          "map_default": "Unknown"
        }
      },
      "day2_icon": {
        "path": "daily.weather_code[1]",
        "format": {
          "map_lookup": "weather_code_icon_day",
          "map_default": "/icons/meteocons/overcast-day.raw"
        }
      }
    }
  },
  "ui": {
    "title": "Forecast",
    "nodes": [
      {
        "type": "label",
        "x": 6,
        "y": 4,
        "font": 2,
        "color": "#B0BEC5",
        "text": "Forecast:"
      },
      {
        "type": "icon",
        "x": 6,
        "y": 24,
        "w": 28,
        "h": 28,
        "path": "{{day1_icon}}"
      },
      {
        "type": "label",
        "x": 40,
        "y": 20,
        "font": 1,
        "color": "#E0E0E0",
        "text": "{{day1_name}}"
      },
      {
        "type": "label",
        "x": 40,
        "y": 36,
        "font": 1,
        "color": "#E0E0E0",
        "text": "{{day1_min}}/{{day1_max}} {{pref.temp_unit}}"
      },
      {
        "type": "icon",
        "x": 6,
        "y": 56,
        "w": 28,
        "h": 28,
        "path": "{{day2_icon}}"
      },
      {
        "type": "label",
        "x": 40,
        "y": 52,
        "font": 1,
        "color": "#E0E0E0",
        "text": "{{day2_name}}"
      },
      {
        "type": "label",
        "x": 40,
        "y": 68,
        "font": 1,
        "color": "#E0E0E0",
        "text": "{{day2_min}}/{{day2_max}} {{pref.temp_unit}}"
      }
    ]
  }
}
